# ── Google AdSense ────────────────────────────────────────────────────────────
# Publisher ID is already hardcoded (ca-pub-2011454284047011).
#
# You need at least ONE ad slot ID from your AdSense dashboard:
#   https://www.google.com/adsense/ → Ads → By ad unit → Display ads → Create
#
# OPTION A — single slot for all positions (simplest, one ad unit required):
NEXT_PUBLIC_ADSENSE_SLOT=1234567890
#
# OPTION B — individual slots per position (takes precedence over the above):
# NEXT_PUBLIC_ADSENSE_SLOT_TOP_LEADERBOARD=1111111111
# NEXT_PUBLIC_ADSENSE_SLOT_BELOW_TOOL=2222222222
# NEXT_PUBLIC_ADSENSE_SLOT_SIDEBAR_RECT=3333333333
#
# For Cloudflare Pages: add NEXT_PUBLIC_ADSENSE_SLOT under
#   Pages → Settings → Environment variables → Production
# The variable is baked in at build time (static export).
